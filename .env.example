# Example .env for Git Commit Copilot
# Copy this to .env and fill in your API key.

# Required: Google Cloud / Gemini API key
GOOGLE_API_KEY=your_api_key_here

# Optional: path to a git repository to operate on
# GIT_REPO_PATH=C:/path/to/repo

# Preferred Gemini model
# GEMINI_MODEL=gemini-3.1-flash-lite
